        // Copy to Google Docs format
        function copyToGoogleDocs() {
            const el = document.getElementById('document-preview-container');
            const selection = window.getSelection();
            const range = document.createRange();
            
            // Unhide temporarily if hidden to copy
            const wasHidden = el.classList.contains('hidden');
            if(wasHidden) el.classList.remove('hidden');

            range.selectNodeContents(el);
            selection.removeAllRanges();
            selection.addRange(range);
            
            try {
                document.execCommand('copy');
                selection.removeAllRanges();
                showToast('Tersalin ke Clipboard! Membuka Google Docs...');
                setTimeout(() => { window.open('https://docs.new', '_blank'); }, 1000);
            } catch (err) {
                console.error("Gagal menyalin text:", err);
                showToast('Gagal menyalin, periksa izin browser.');
            }

            if(wasHidden) el.classList.add('hidden');
        }

        // Export to Word
        function exportToWord() {
            const content = document.getElementById('document-preview-container').innerHTML;
            const header = "<html xmlns:o='urn:schemas-microsoft-com:office:office' xmlns:w='urn:schemas-microsoft-com:office:word' xmlns='http://www.w3.org/TR/REC-html40'><head><meta charset='utf-8'><title>Export HTML To Doc</title><style>table{border-collapse:collapse;width:100%}th,td{border:1px solid black;padding:8px;vertical-align:top;text-align:justify}th{background-color:#f3f4f6;text-align:left}</style></head><body>";
            const footer = "</body></html>";
            const sourceHTML = header + content + footer;
            
            const blob = new Blob(['\ufeff', sourceHTML], { type: 'application/msword' });
            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.download = `RPM_${document.getElementById('mataPelajaran').value}_${document.getElementById('kelas').value}.doc`;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            URL.revokeObjectURL(url);
            showToast('Dokumen Word berhasil diunduh!');
        }
